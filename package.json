{
  "name": "vedha",
  "version": "1.0.14",
  "main": "dist-electron/main.js",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.0.9"
  },
  "scripts": {
    "clean": "rimraf dist dist-electron",
    "build": "node scripts/build-config.js && cross-env NODE_ENV=production rimraf dist dist-electron release && vite build && tsc -p tsconfig.electron.json && electron-builder",
    "typecheck:renderer": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "typecheck": "concurrently \"pnpm:typecheck:renderer\" \"pnpm:typecheck:electron\"",
    "lint": "biome check --diagnostic-level=error --reporter=summary .",
    "lint:fix": "biome check --write --diagnostic-level=error --reporter=summary .",
    "lint:ci": "biome check --diagnostic-level=error --reporter=summary .",
    "dev:watch-electron": "cross-env NODE_ENV=development tsc -w -p tsconfig.electron.json",
    "dev:serve-renderer": "cross-env NODE_ENV=development vite",
    "dev": "concurrently \"npx pnpm run dev:watch-electron\" \"npx pnpm run dev:serve-renderer\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:electron": "jest --config=jest.electron.config.js --passWithNoTests",
    "test:renderer": "jest --config=jest.renderer.config.js --passWithNoTests"
  },
  "build": {
    "appId": "com.vedha.vedha-app",
    "productName": "Vedha",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "electron/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "asar": true,
    "compression": "maximum",
    "generateUpdatesFilesForAllChannels": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Vedha-Mac-${arch}-${version}.${ext}",
      "icon": "assets/icons/mac/icon-256x256.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "identity": "Developer ID Application",
      "type": "distribution",
      "protocols": {
        "name": "vedha-protocol",
        "schemes": [
          "vedha"
        ]
      },
      "notarize": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/win/icon-256x256.ico",
      "artifactName": "Vedha-Windows-${version}.${ext}",
      "protocols": {
        "name": "vedha-protocol",
        "schemes": [
          "vedha"
        ]
      }
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icons/png/icon-256x256.png",
      "artifactName": "Vedha-Linux-${version}.${ext}",
      "protocols": {
        "name": "vedha-protocol",
        "schemes": [
          "vedha"
        ]
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vedha",
        "repo": "vedha-app",
        "private": false,
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  },
  "keywords": [
    "electron",
    "desktop",
    "coding",
    "interview",
    "assistant",
    "developer-tools",
    "react",
    "typescript"
  ],
  "author": "dkhorev",
  "license": "MIT",
  "description": "Invisible overlay UI for DSA interviews.",
  "homepage": "https://github.com/vedha/vedha-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/vedha/vedha-app.git"
  },
  "bugs": {
    "url": "https://github.com/vedha/vedha-app/issues"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@electron/notarize": "^3.1.1",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/color": "^4.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
